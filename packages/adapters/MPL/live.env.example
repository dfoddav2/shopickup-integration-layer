# MPL live test environment variables
# Copy to packages/adapters/MPL/.env.live and fill in your sandbox credentials

MPL_LIVE_API_KEY=your-api-key
MPL_LIVE_API_SECRET=your-api-secret
MPL_LIVE_ACCOUNTING_CODE=your-accounting-code
MPL_LIVE_AGREEMENT_CODE=your-agreement-code
MPL_LIVE_BANK_ACCOUNT_NUMBER=your-bank-account-number
MPL_LIVE_BASE_URL=https://sandbox.api.posta.hu/v2/mplapi
