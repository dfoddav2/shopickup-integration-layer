{
  "name": "@shopickup/adapters-mpl",
  "version": "0.0.5",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/dfoddav2/shopickup-integration-layer/tree/main/packages/adapters/MPL",
  "repository": {
    "type": "git",
    "url": "https://github.com/dfoddav2/shopickup-integration-layer.git",
    "directory": "packages/adapters/MPL"
  },
  "bugs": {
    "url": "https://github.com/dfoddav2/shopickup-integration-layer/issues"
  },
  "description": "MPL shipping carrier adapter for Shopickup",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "dev": "tsc -w -p tsconfig.json",
    "codegen": "openapi-typescript ../../carrier-docs/hu-mpl/hu-mpl.openapi.yaml --output ./src/types/generated.ts"
  },
  "peerDependencies": {
    "@shopickup/core": ">=0.0.2 <0.1.0"
  },
  "devDependencies": {
    "@shopickup/core": "workspace:*",
    "@stoplight/prism-http": "^5.0.0",
    "axios": "^1.6.0",
    "openapi-typescript": "^6.7.0",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^4.3.5"
  },
  "keywords": [
    "shipping",
    "carrier",
    "mpl",
    "adapter",
    "logistics",
    "hungary"
  ],
  "author": "Shopickup Contributors",
  "license": "MIT"
}
