{
  "name": "@shopickup/adapters-gls",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/dfoddav2/shopickup-integration-layer/tree/main/packages/adapters/GLS",
  "repository": {
    "type": "git",
    "url": "https://github.com/dfoddav2/shopickup-integration-layer.git",
    "directory": "packages/adapters/GLS"
  },
  "bugs": {
    "url": "https://github.com/dfoddav2/shopickup-integration-layer/issues"
  },
  "description": "GLS shipping carrier adapter for Shopickup (Hungary & Eastern Europe)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    },
    "./validation/parcels": {
      "import": "./dist/validation/parcels.js",
      "types": "./dist/validation/parcels.d.ts"
    },
    "./validation/labels": {
      "import": "./dist/validation/labels.js",
      "types": "./dist/validation/labels.d.ts"
    },
    "./validation/tracking": {
      "import": "./dist/validation/tracking.js",
      "types": "./dist/validation/tracking.d.ts"
    },
    "./capabilities/pickup-points": {
      "import": "./dist/capabilities/pickup-points.js",
      "types": "./dist/capabilities/pickup-points.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "dev": "tsc -w -p tsconfig.json",
    "codegen": "openapi-typescript ../../carrier-docs/hu-gls/hu-gls.openapi.yaml --output ./src/types/generated.ts"
  },
  "peerDependencies": {
    "@shopickup/core": ">=0.0.2 <0.1.0"
  },
  "devDependencies": {
    "@shopickup/core": "workspace:*",
    "@stoplight/prism-http": "^5.0.0",
    "axios": "^1.6.0",
    "openapi-typescript": "^6.7.0",
    "typescript": "^5.4.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^4.3.5"
  },
  "keywords": [
    "shipping",
    "carrier",
    "gls",
    "adapter",
    "logistics",
    "hungary",
    "eastern-europe",
    "pickup-points",
    "apm"
  ],
  "author": "Shopickup Contributors",
  "license": "MIT"
}
