# Copy to `.env.live` in this folder.

GLS_LIVE_USERNAME=your-mygls-email
GLS_LIVE_PASSWORD=your-mygls-password
GLS_LIVE_CLIENT_NUMBER_LIST=12345
GLS_LIVE_WEBSHOP_ENGINE=shopickup/1.0
GLS_LIVE_USE_TEST_API=true
GLS_LIVE_COUNTRY=HU
# GLS pickup-point ID for PSD service.  Format from the public feed is
# <goldId>-PARCELSHOP (e.g. 379-PARCELSHOP).  The value is sent as the PSD
# service parameter.
GLS_LIVE_PICKUP_POINT_ID=379-PARCELSHOP
