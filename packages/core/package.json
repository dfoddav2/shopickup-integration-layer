{
  "name": "@shopickup/core",
  "version": "0.0.7",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/dfoddav2/shopickup-integration-layer",
  "repository": {
    "type": "git",
    "url": "https://github.com/dfoddav2/shopickup-integration-layer.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dfoddav2/shopickup-integration-layer/issues"
  },
  "description": "Shopickup core library - canonical types, adapter interface, and orchestration helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stores": {
      "import": "./dist/stores/index.js",
      "types": "./dist/stores/index.d.ts"
    },
    "./flows": {
      "import": "./dist/flows/index.js",
      "types": "./dist/flows/index.d.ts"
    },
    "./http": {
      "import": "./dist/http/index.js",
      "types": "./dist/http/index.d.ts"
    },
    "./http/axios-client": {
      "import": "./dist/http/axios-client.js",
      "types": "./dist/http/axios-client.d.ts"
    },
    "./http/fetch-client": {
      "import": "./dist/http/fetch-client.js",
      "types": "./dist/http/fetch-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --run src",
    "dev": "tsc -w -p tsconfig.json"
  },
  "keywords": [
    "shipping",
    "carrier",
    "adapter",
    "logistics"
  ],
  "author": "David Fodor",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "zod": "^4.3.5"
  }
}
