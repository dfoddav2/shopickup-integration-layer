### examples/functions/.env.example
# Copy this file to `examples/functions/.env` (gitignored) and populate with your
# carrier credentials and options for running the functions CLI.
# Do NOT commit your real secrets.

# MPL credentials (either API key pair OR OAuth2 token)
# Use API key + secret for Basic auth flows, or oauth2 token if you already
# exchanged via /oauth2/token.
MPL_API_KEY=
MPL_API_SECRET=
# Or, supply an OAuth2 access token instead of apiKey/apiSecret
MPL_OAUTH_TOKEN=

# Foxpost credentials
FOXPOST_API_KEY=
FOXPOST_BASIC_USERNAME=
FOXPOST_BASIC_PASSWORD=

# GLS credentials
GLS_USERNAME=
GLS_PASSWORD=
GLS_CLIENT_ID=

# MPL accounting code is required for many operations (labels, close, parcels)
MPL_ACCOUNTING_CODE=

# MPL agreement code / bank account (optional)
MPL_AGREEMENT_CODE=
MPL_MEGALLAPODASKOD=
MPL_BANK_ACCOUNT_NUMBER=

# Optional: tell the functions to hit MPL sandbox endpoints
# true|false (default: false)
USE_TEST_API=false

# GLS options are usually provided per-fixture, not env

# Example: if you run the dev-server and want the functions to reuse its HTTP
# client, set the base URL for HTTP requests here (optional)
HTTP_BASE_URL=
