{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "typeRoots": ["./types", "./node_modules/@types", "../node_modules/@types"]
  },
  "include": ["**/*.ts"]
}
